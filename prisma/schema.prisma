// SwordCraft v2 - Game Save Schema (локальная SQLite для Prisma CLI)
// Облачные сейвы: src/lib/db.ts + src/app/api/save/route.ts — держите поля в sync с моделью ниже

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ================================
// ОСНОВНОЕ СОХРАНЕНИЕ ИГРЫ
// ================================

model GameSave {
  id       String @id @default(cuid())
  playerId String @unique

  // === ДАННЫЕ ИГРОКА ===
  level      Int @default(1)
  experience Int @default(0)
  fame       Int @default(0)

  // === РЕСУРСЫ ===
  resources String @default("{}")

  // === СТАТИСТИКА ===
  statistics String @default("{}")

  // === РАБОЧИЕ И ЗДАНИЯ ===
  workers    String @default("[]")
  buildings  String @default("[]")
  maxWorkers Int    @default(3)

  // === КРАФТ ===
  activeCraft          String @default("{}")
  activeRefining       String @default("{}")
  weaponInventory      String @default("{\"weapons\":[]}")
  unlockedRecipes      String @default("{\"weaponRecipes\":[\"sword_iron\",\"dagger_iron\",\"sword_bronze\",\"dagger_bronze\",\"sword_copper\",\"dagger_copper\"],\"refiningRecipes\":[]}")
  recipeSources        String @default("[]")
  unlockedEnchantments String @default("[]")

  // === ГИЛЬДИЯ ===
  guild             String @default("{}")
  knownAdventurers  String @default("[]")

  // === ОРДЕРА ===
  orders String @default("{}")

  // === ОБУЧЕНИЕ ===
  tutorial String @default("{\"isActive\":true,\"currentStep\":0,\"skipped\":false,\"completedSteps\":[]}")

  // === ЗНАНИЯ МАТЕРИАЛОВ (энциклопедия / крафт) ===
  materialKnowledge String @default("{}")

  // === КРАФТ V2 (план, этапы, превью) — синхрон с Turso ALTER craftV2Persisted ===
  craftV2Persisted String @default("{}")

  // === МЕТАДАННЫЕ ===
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  playTime    Int      @default(0)
  saveVersion Int      @default(2)

  @@map("game_saves")
}

// ================================
// ИСТОРИЯ СОХРАНЕНИЙ (для отката)
// ================================

model SaveHistory {
  id         String   @id @default(cuid())
  gameSaveId String
  snapshot   String
  createdAt  DateTime @default(now())

  @@index([gameSaveId])
  @@map("save_history")
}
